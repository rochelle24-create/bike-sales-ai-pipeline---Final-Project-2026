# IMPORTANT: Do not put your API key here in this example file, only in the .env file.
# The .env file is protected by .gitignore and will NOT be committed to the repo.
# This .env.example file IS committed to the repo as a safe template only.
#
# Copy this file to .env and add your real key
# Only needed for Anthropic options (2 or 3)
# Leave blank if using Ollama (option 1) - it is free
ANTHROPIC_API_KEY=your-anthropic-api-key-here
